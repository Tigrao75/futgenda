rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isGroupMember(groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    function getRole(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role;
    }

    function isOwner(groupId) {
      return isGroupMember(groupId) && getRole(groupId) == "owner";
    }

    function isAdmin(groupId) {
      return isGroupMember(groupId) && getRole(groupId) == "admin";
    }

    function isOwnerOrAdmin(groupId) {
      return isOwner(groupId) || isAdmin(groupId);
    }

    match /users/{userId} {
      allow create: if isSelf(userId);
      allow read: if signedIn();
      allow update, delete: if isSelf(userId);
    }

    match /{path=**}/members/{memberId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /groups/{groupId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.id == groupId;

      allow read: if isGroupMember(groupId);

      allow update: if isOwnerOrAdmin(groupId);

      allow delete: if isOwner(groupId);

      // ----------------------------
      // Events (Pelada)
      // ----------------------------
      match /events/{eventId} {
        allow read: if isGroupMember(groupId);

        allow create: if signedIn()
          && isOwnerOrAdmin(groupId);

        allow update: if signedIn()
          && isOwnerOrAdmin(groupId);

        allow delete: if signedIn()
          && isOwner(groupId);

        match /participants/{userId} {
          allow read: if isGroupMember(groupId);

          allow create: if signedIn()
            && isOwnerOrAdmin(groupId);

          allow update: if signedIn()
            && (
              isOwnerOrAdmin(groupId)
              || request.auth.uid == userId
              || (
                isGroupMember(groupId)
                && resource.data.status == 'lista_espera'
                && request.resource.data.status == 'confirmado'
                && request.resource.data.userId == resource.data.userId
                && request.resource.data.role == resource.data.role
                && request.resource.data.type == resource.data.type
                && request.resource.data.confirmedAt == resource.data.confirmedAt
              )
            );

          allow delete: if signedIn()
            && isOwnerOrAdmin(groupId);
        }
      }

      match /members/{memberId} {
        allow read: if isGroupMember(groupId);

        allow create: if signedIn()
          && memberId == request.resource.data.userId
          && request.resource.data.type in ["mensalista", "avulso"]
          && (
            (
              request.resource.data.role == "owner"
              && request.resource.data.userId == request.auth.uid
              && getAfter(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid
            )
            ||
            (
              isOwnerOrAdmin(groupId)
              && request.resource.data.role in ["member", "admin"]
            )
          );

        allow update: if signedIn()
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.role in ["member", "admin"]
          && request.resource.data.type in ["mensalista", "avulso"]
          && (
            isOwner(groupId)
            ||
            (
              isAdmin(groupId)
              && resource.data.role != "owner"
            )
          );

        allow delete: if signedIn()
          && resource.data.role != "owner"
          && isOwnerOrAdmin(groupId);
      }
    }
  }
}